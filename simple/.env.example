# Django
SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=False
ALLOWED_HOSTS=your-domain.example,www.your-domain.example
TIME_ZONE=Asia/Irkutsk

# PostgreSQL
DB_NAME=re_crm
DB_USER=postgres
DB_PASSWORD=replace-with-strong-db-password
DB_HOST=localhost
DB_PORT=5432
GAR_ROOT=

# DaData — подсказки адресов (сервис https://dadata.ru/)
# ВАЖНО: URL должен быть полным, до /suggest/address — иначе получите 404.
DADATA_API_URL=https://suggestions.dadata.ru/suggestions/api/4_1/rs/suggest/address
DADATA_API_KEY=replace-with-dadata-api-key

# 2GIS Places API — обогащение объектов данными (описание, фото) при seed_data.
# Получить ключ: https://dev.2gis.ru/
TWOGIS_API_KEY=replace-with-2gis-api-key

# Vite / django-vite
DJANGO_VITE_DEV_MODE=False
DJANGO_VITE_DEV_SERVER_HOST=localhost
DJANGO_VITE_DEV_SERVER_PORT=5173

# SMTP / Email — конфигурация для Яндекс.Почты
# Для Яндекса используйте пароль приложения, не обычный пароль аккаунта.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_TIMEOUT=30
EMAIL_HOST_USER=noreply@your-domain.example
EMAIL_HOST_PASSWORD=replace-with-smtp-app-password
DEFAULT_FROM_EMAIL=noreply@your-domain.example
EMAIL_VERIFICATION_CODE_TTL_MINUTES=15
EMAIL_FALLBACK_ENABLED=True
EMAIL_FALLBACK_HOST=smtp.yandex.ru
EMAIL_FALLBACK_PORT=587
EMAIL_FALLBACK_USE_SSL=False
EMAIL_FALLBACK_USE_TLS=True
EMAIL_FALLBACK_TIMEOUT=30
EMAIL_FALLBACK_USER=noreply@your-domain.example
EMAIL_FALLBACK_PASSWORD=replace-with-smtp-app-password

# Альтернативная конфигурация (если SSL/465 заблокирован файрволом):
# EMAIL_PORT=587
# EMAIL_USE_SSL=False
# EMAIL_USE_TLS=True

# Email templates
AGENCY_NAME=Агентство недвижимости
AGENCY_LEGAL_NAME=ООО РИЭЛТ
AGENCY_PUBLIC_URL=https://your-domain.example
AGENCY_REPLY_TO=noreply@your-domain.example
AGENCY_PHONE=+7 (9836) 90-38-54
AGENCY_ADDRESS=г. Иркутск, ул. Ленина, д. 5
AGENCY_INN=3808000000
AGENCY_KPP=380801001
AGENCY_OGRN=1023800000000
AGENCY_BANK_DETAILS=р/с 40702810000000000001; БИК 042520607; ПАО Сбербанк
AGENCY_SIGNATORY_NAME=Березин Александр Андреевич
AGENCY_SIGNATORY_TITLE=Генеральный директор
AGENCY_SIGNATORY_BASIS=Устава

# Production security
CORS_ALLOWED_ORIGINS=https://your-domain.example,https://www.your-domain.example
CSRF_TRUSTED_ORIGINS=https://your-domain.example,https://www.your-domain.example
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
ENABLE_API_DOCS=False

# Sberbank Acquiring
SBER_API_URL=https://3dsec.sberbank.ru/payment/rest/
SBER_USERNAME=replace-with-sber-api-username
SBER_PASSWORD=replace-with-sber-api-password
SBER_SANDBOX=True
SBER_PAYMENT_TIMEOUT=10
SBER_VIEWING_AMOUNTS={"apartment":"500.00","room":"500.00","house":"1000.00","commercial":"2000.00","land":"1500.00","garage":"300.00"}
