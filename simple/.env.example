# DaData — подсказки адресов (сервис https://dadata.ru/)
# Ключ API хранится ТОЛЬКО на сервере и никогда не передаётся в браузер.
# ВАЖНО: URL должен быть полным, до /suggest/address — иначе получите 404.
DADATA_API_URL=https://suggestions.dadata.ru/suggestions/api/4_1/rs/suggest/address
DADATA_API_KEY=8ceded5bba84e0bd3f20cd7a36057324dc680563

# Vite / django-vite
DJANGO_VITE_DEV_MODE=True
DJANGO_VITE_DEV_SERVER_HOST=localhost
DJANGO_VITE_DEV_SERVER_PORT=5173

# SMTP / Email — рабочая конфигурация для mail.ru / bk.ru / list.ru / inbox.ru.
#
# ВАЖНО: для mail.ru используем порт 465 + SSL (это самая стабильная схема).
# Порт 587 + STARTTLS у mail.ru часто завершается TimeoutError в smtplib.
#
# Пароль — это НЕ пароль от ящика, а отдельный «пароль для внешних
# приложений», который выпускается в настройках безопасности почты:
#   https://account.mail.ru/user/2-step-auth/passwords
# Без него mail.ru вернёт «Authentication required» или просто рвёт
# соединение по таймауту.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mail.ru
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_TIMEOUT=30
EMAIL_HOST_USER=danil_naumov_90@bk.ru
EMAIL_HOST_PASSWORD=ваш_пароль_для_внешних_приложений
DEFAULT_FROM_EMAIL=danil_naumov_90@bk.ru

# Альтернативная конфигурация (если SSL/465 заблокирован файрволом):
# EMAIL_PORT=587
# EMAIL_USE_SSL=False
# EMAIL_USE_TLS=True

# Email templates
AGENCY_NAME=Агентство недвижимости
AGENCY_PUBLIC_URL=http://127.0.0.1:8000
AGENCY_REPLY_TO=danil_naumov_90@bk.ru
